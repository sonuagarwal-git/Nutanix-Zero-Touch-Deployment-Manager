# =============================================================================
# Nutanix ZTI Deployment Manager - Environment Configuration Template
# =============================================================================
# INSTRUCTIONS
#   1. Copy this file to .env in the same directory:
#        copy .env.example .env          (Windows cmd)
#        Copy-Item .env.example .env     (PowerShell)
#   2. Replace placeholder values with your actual settings.
#   3. Restart the service (or Node.js process) for changes to take effect.
#
#   Lines starting with # are comments and are ignored by the application.
#   Do NOT commit .env to source control - it contains the session secret.
# =============================================================================


# --- Company Branding --------------------------------------------------------
# Displayed in the browser tab title, nav bar, and login page.
# If public/images/logo.png is present it is shown instead of this text label.
# No server restart required after editing this value (it is read on every request).

COMPANY_NAME=Your Company Name


# --- Web Server --------------------------------------------------------------
# HTTPS port the application listens on.
# Default: 3443  (change if another service already uses this port)

PORT=3443

# Public-facing URL of this server.
# Used in welcome emails sent to newly imported AD/LDAP users.
# Must use the hostname or IP that remote clients can reach, and match PORT above.
# Example: https://jump-server.corp.example.com:3443

SERVER_URL=https://your-server-name:3443


# --- Security ----------------------------------------------------------------
# Long random string used to sign and verify browser session cookies.
# A fresh value is generated automatically by start.ps1.
# To generate one manually with PowerShell:
#
#   $b = New-Object byte[] 32
#   [System.Security.Cryptography.RNGCryptoServiceProvider]::new().GetBytes($b)
#   [Convert]::ToBase64String($b)
#
# WARNING: Replace this placeholder before going live.
# WARNING: Never share or commit this value to source control.

SESSION_SECRET=REPLACE_WITH_A_GENERATED_SECRET


# --- SMTP / Email Notifications ----------------------------------------------
# Used to send welcome emails when AD/LDAP users are imported into the app.
#
# These values act as fallback defaults only.
# Full SMTP settings (host, port, credentials, TLS, sender) can also be
# configured through the web UI at Admin -> SMTP Settings, which writes to
# smtp-config.json and takes precedence over the values defined here.

# Hostname or IP address of your SMTP relay / mail server
SMTP_HOST=smtp.example.com

# SMTP port:
#   25  - unauthenticated relay (internal mail servers, most common)
#   587 - STARTTLS (authenticated, requires SMTP_PASS)
#   465 - SMTPS / implicit TLS (authenticated, requires SMTP_PASS)
SMTP_PORT=25

# Email address shown in the From header of outgoing messages
SMTP_USER=noreply@company.com


# --- Development (optional) --------------------------------------------------
# Set to 'development' to include full stack traces in API error responses.
# Leave commented out or set to 'production' for live / production deployments.

# NODE_ENV=production
