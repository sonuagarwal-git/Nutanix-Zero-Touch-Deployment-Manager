# Email Configuration for User Import Notifications
# Copy this file to .env if you want to set default SMTP values
# Note: SMTP settings can also be configured through the web interface (recommended)

# SMTP Server Configuration (optional - can be set in web UI)
SMTP_HOST=smtp.example.com
SMTP_PORT=25

# Email Account for Sending Notifications (optional - can be set in web UI)
SMTP_USER=noreply@vestas.com

# Server URL (optional - can be set in web UI)
# This should be the public HTTPS URL where users can access the portal
SERVER_URL=https://your-server-hostname:3443

# Note: The application now supports SMTP configuration through the web interface.
# Navigate to User Management > SMTP Settings to configure email notifications.
# No authentication is required for SMTP servers.
